{
  "name": "angular-i18n-demo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "extract-i18n": "ng extract-i18n --output-path src/i18n --format json",
    "serve:de": "ng serve --configuration=de",
    "serve:en": "ng serve --configuration=development",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/router": "22.0.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@angular/localize": "22.0.2",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  }
}
