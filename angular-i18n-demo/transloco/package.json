    "@angular/platform-browser": "22.0.5",
    "@angular/router": "22.0.5",
    "@jsverse/transloco": "8.4.0",
    "@jsverse/transloco-locale": "8.4.0",
    "@jsverse/transloco-messageformat": "8.4.0",
    "@jsverse/transloco-persist-lang": "8.4.0",
    "@jsverse/transloco-persist-translations": "8.4.0",
    "@jsverse/transloco-preload-langs": "8.4.0",
    "dfx-transloco-markup": "22.0.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
