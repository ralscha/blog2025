{
  "name": "sw-update",
  "version": "0.0.1",
  "scripts": {
    "prebuild": "bun scripts/write-build-info.mjs",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "generate:pwa-assets": "node scripts/generate-pwa-assets.mjs",
    "serve": "bun run scripts/serve.ts",
    "watch": "ng build --watch --configuration development",
    "format": "npx prettier --write .",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/core": "21.2.7",
    "@angular/forms": "21.2.7",
    "@angular/platform-browser": "21.2.7",
    "@angular/router": "21.2.7",
    "@angular/service-worker": "21.2.7",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.3.1",
    "@angular/build": "21.2.6",
    "@angular/cli": "21.2.6",
    "@angular/compiler-cli": "21.2.7",
    "@eslint/js": "10.0.1",
    "angular-eslint": "21.3.1",
    "eslint": "10.2.0",
    "prettier": "3.8.1",
    "pwa-asset-generator": "8.1.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  }
}
