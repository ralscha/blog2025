{
  "name": "sw-update",
  "version": "0.0.1",
  "scripts": {
    "prebuild": "bun scripts/write-build-info.mjs",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "generate:pwa-assets": "node scripts/generate-pwa-assets.mjs",
    "serve": "bun run scripts/serve.ts",
    "watch": "ng build --watch --configuration development",
    "format": "npx prettier --write .",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/router": "22.0.2",
    "@angular/service-worker": "22.0.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@eslint/js": "10.0.1",
    "angular-eslint": "22.0.0",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "pwa-asset-generator": "8.1.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
